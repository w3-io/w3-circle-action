{
  "name": "w3-circle-action",
  "version": "1.0.0",
  "private": true,
  "description": "W3 Circle Action — CCTP cross-chain USDC transfers via Circle APIs",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.js -o dist",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/ __tests__/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "all": "npm run format:write && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@solana/web3.js": "^1.98.4",
    "@w3-io/action-core": "^0.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0"
  }
}
