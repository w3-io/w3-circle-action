{
  "name": "w3-circle-action",
  "version": "1.0.0",
  "private": true,
  "description": "W3 Circle Action — CCTP cross-chain USDC transfers via Circle APIs",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/",
    "test": "node --test test/*.test.js",
    "build": "ncc build src/index.js -o dist --target es2022 --minify",
    "all": "npm run format && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@solana/web3.js": "^1.98.4",
    "@w3-io/action-core": "^0.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "rollup": "^4.28.0"
  }
}
